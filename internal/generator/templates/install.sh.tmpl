#!/usr/bin/env sh
set -eu

BINARY="{{ .Manifest.Name }}"
REPO="${REPO:-{{ .Release.Repo }}}"
VERSION="${VERSION:-}"

if [ -z "$REPO" ]; then
  echo "REPO is not configured. Regenerate this project with --repo owner/name or set REPO=owner/name before running this installer." >&2
  exit 1
fi

require_command() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "missing required command: $1" >&2
    exit 1
  fi
}

detect_os() {
  case "$(uname -s)" in
    Darwin) echo "darwin" ;;
    Linux) echo "linux" ;;
    *)
      echo "unsupported operating system: $(uname -s)" >&2
      exit 1
      ;;
  esac
}

detect_arch() {
  case "$(uname -m)" in
    x86_64|amd64) echo "amd64" ;;
    arm64|aarch64) echo "arm64" ;;
    *)
      echo "unsupported architecture: $(uname -m)" >&2
      exit 1
      ;;
  esac
}

latest_tag() {
  curl -fsSL "https://api.github.com/repos/$REPO/releases/latest" | sed -n 's/.*"tag_name":[[:space:]]*"\([^"]*\)".*/\1/p' | head -n 1
}

checksum_command() {
  if command -v sha256sum >/dev/null 2>&1; then
    echo "sha256sum"
    return
  fi
  if command -v shasum >/dev/null 2>&1; then
    echo "shasum -a 256"
    return
  fi
  echo ""
}

install_dir() {
  if [ -n "${INSTALL_DIR:-}" ]; then
    echo "$INSTALL_DIR"
    return
  fi
  if [ -w /usr/local/bin ]; then
    echo "/usr/local/bin"
    return
  fi
  echo "${HOME}/.local/bin"
}

require_command curl
require_command tar
require_command awk
require_command grep
require_command install

OS="$(detect_os)"
ARCH="$(detect_arch)"
TAG="$VERSION"
if [ -z "$TAG" ]; then
  TAG="$(latest_tag)"
fi
if [ -z "$TAG" ]; then
  echo "failed to determine release version from GitHub" >&2
  exit 1
fi

VERSION_NO_V="${TAG#v}"
ARCHIVE="${BINARY}_${VERSION_NO_V}_${OS}_${ARCH}.tar.gz"
CHECKSUMS="checksums.txt"
BASE_URL="https://github.com/${REPO}/releases/download/${TAG}"
TMP_DIR="$(mktemp -d)"
trap 'rm -rf "$TMP_DIR"' EXIT INT TERM

curl -fsSL "${BASE_URL}/${ARCHIVE}" -o "${TMP_DIR}/${ARCHIVE}"
curl -fsSL "${BASE_URL}/${CHECKSUMS}" -o "${TMP_DIR}/${CHECKSUMS}"

SUM_CMD="$(checksum_command)"
if [ -n "$SUM_CMD" ]; then
  EXPECTED="$(grep " ${ARCHIVE}\$" "${TMP_DIR}/${CHECKSUMS}" | awk '{print $1}')"
  if [ -z "$EXPECTED" ]; then
    echo "checksum entry not found for ${ARCHIVE}" >&2
    exit 1
  fi
  ACTUAL="$($SUM_CMD "${TMP_DIR}/${ARCHIVE}" | awk '{print $1}')"
  if [ -n "$EXPECTED" ] && [ "$EXPECTED" != "$ACTUAL" ]; then
    echo "checksum mismatch for ${ARCHIVE}" >&2
    exit 1
  fi
fi

tar -xzf "${TMP_DIR}/${ARCHIVE}" -C "${TMP_DIR}"

TARGET_DIR="$(install_dir)"
mkdir -p "$TARGET_DIR"
install -m 0755 "${TMP_DIR}/${BINARY}" "${TARGET_DIR}/${BINARY}"

echo "installed ${BINARY} to ${TARGET_DIR}/${BINARY}"
case ":$PATH:" in
  *":${TARGET_DIR}:"*) ;;
  *)
    echo "note: ${TARGET_DIR} is not on PATH" >&2
    ;;
esac
