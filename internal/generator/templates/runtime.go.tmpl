const (
	cliName                 = "{{ .Manifest.Name }}"
	baseURLEnv              = "{{ .Manifest.EnvPrefix }}_BASE_URL"
	headersEnv              = "{{ .Manifest.EnvPrefix }}_HEADERS_JSON"
	overridesEnv            = "{{ .Manifest.EnvPrefix }}_OVERRIDES_JSON"
	maxResponseBytesEnv     = "{{ .Manifest.EnvPrefix }}_MAX_RESPONSE_BYTES"
	defaultMaxResponseBytes = 20 << 20
)

//go:embed openapi.json manifest.json
var embeddedFiles embed.FS

var (
	manifestOnce sync.Once
	manifestData Manifest
	manifestErr  error

	operationIndexOnce sync.Once
	operationIndexData map[string]OperationManifest
	operationIndexErr  error

	docOnce sync.Once
	docData *openapi3.T
