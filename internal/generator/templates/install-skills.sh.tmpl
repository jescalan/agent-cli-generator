#!/usr/bin/env sh
set -eu

REPO_URL="${REPO_URL:-{{- if .Release.HasRepo -}}https://github.com/{{ .Release.Repo }}{{- end -}}}"
SKILL_NAME="{{ .Skills.Name }}"

if [ -z "$REPO_URL" ]; then
  echo "REPO_URL is not configured. Regenerate this project with --repo owner/name or set REPO_URL=https://github.com/owner/name before running this installer." >&2
  exit 1
fi

if ! command -v npx >/dev/null 2>&1; then
  echo "missing required command: npx" >&2
  exit 1
fi

echo "installing ${SKILL_NAME} from ${REPO_URL}"
npx skills add "$REPO_URL" --skill "$SKILL_NAME"
echo "installed skill: $SKILL_NAME"
